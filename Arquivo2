  // Convert hex (#rrggbb) to HSL {h:0-360, s:0-100, l:0-100}
  function hexToHSL(hex) {
    hex = hex.replace('#','');
    if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
    const r = parseInt(hex.substring(0,2),16)/255;
    const g = parseInt(hex.substring(2,4),16)/255;
    const b = parseInt(hex.substring(4,6),16)/255;
    const max = Math.max(r,g,b), min = Math.min(r,g,b);
    let h=0, s=0, l=(max+min)/2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d/(2-max-min) : d/(max+min);
      if (max === r) h = ((g-b)/d + (g<b?6:0));
      else if (max === g) h = ((b-r)/d + 2);
      else h = ((r-g)/d + 4);
      h *= 60;
    }
    return { h: Math.round(h), s: Math.round(s*100), l: Math.round(l*100) };
  }

  // Map HSL values to the best palette
  function hslToPalette(h, s, l) {
    const isLight = l > 55;
    const isGray  = s < 10;

    // Very desaturated / gray
    if (isGray) return isLight ? P.lightNeutral : P.neutral;

    // Hue-based matching
    // Red: 0-15, 345-360
    // Amber/Orange: 15-45
    // Yellow/Gold: 45-65
    // Green: 65-165
    // Cyan/Teal: 165-195
    // Blue: 195-265
    // Purple: 265-290
    // Plum/Magenta: 290-345

    if (h >= 345 || h < 15)   return isLight ? P.lightRose    : P.red;
    if (h >= 15  && h < 45)   return isLight ? P.lightAmber   : P.amber;
    if (h >= 45  && h < 65)   return isLight ? P.lightAmber   : P.amber;
    if (h >= 65  && h < 165)  return isLight ? P.lightGreen   : P.green;
    if (h >= 165 && h < 195)  return isLight ? P.lightBlue    : P.blue;
    if (h >= 195 && h < 265)  return isLight ? P.lightBlue    : P.blue;
    if (h >= 265 && h < 290)  return isLight ? P.lightPurple  : P.purple;
    if (h >= 290 && h < 345)  return isLight ? P.lightRose    : P.plum;

    return isLight ? P.lightNeutral : P.purple;
  }

  // Detect palette from a hex color string
  function detectPaletteFromColor(hex) {
    const { h, s, l } = hexToHSL(hex);
    return hslToPalette(h, s, l);
  }

  // Detect palette from an image URL using canvas pixel sampling
  function detectPaletteFromImage(imgSrc, callback) {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = function() {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      // Sample at small size for speed
      const sampleW = 64, sampleH = 64;
      canvas.width = sampleW;
      canvas.height = sampleH;
      ctx.drawImage(img, 0, 0, sampleW, sampleH);

      const data = ctx.getImageData(0, 0, sampleW, sampleH).data;
      let totalR=0, totalG=0, totalB=0;
      let count = 0;

      // Sample every 4th pixel in a grid
      for (let i = 0; i < data.length; i += 16) {
        totalR += data[i];
        totalG += data[i+1];
        totalB += data[i+2];
        count++;
      }

      if (count === 0) { callback(P.purple); return; }

      const avgR = Math.round(totalR/count);
      const avgG = Math.round(totalG/count);
      const avgB = Math.round(totalB/count);
      const hex = '#' + [avgR,avgG,avgB].map(c=>c.toString(16).padStart(2,'0')).join('');

      callback(detectPaletteFromColor(hex));
    };
    img.onerror = function() {
      // Fallback if CORS or load fails
      callback(P.purple);
    };
    img.src = imgSrc;
  }


