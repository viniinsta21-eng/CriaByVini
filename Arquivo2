<!-- ══════════════════════════════════════
     GALLERY SCRIPT
     ══════════════════════════════════════ -->
<script>
(function(){
    const DEFAULT_GEN='the-imaginarium',DEFAULT_SUB='public',SITE_URL='https://perchance.org/the-imaginarium';
    const STORAGE_KEYS={gen:'imag_galGen',sub:'imag_galSub',tag:'imag_galTag',bad:'imag_galBad'};
    const modal=document.getElementById('galleryModal');
    if(!modal)return;
    const closeBtn=document.getElementById('closeGalleryBtn'),genSelect=document.getElementById('galGenSelect'),genInput=document.getElementById('galGenInput'),subSelect=document.getElementById('galSubSelect'),subInput=document.getElementById('galSubInput'),tagInput=document.getElementById('galTagInput'),badInput=document.getElementById('galBadInput'),filterBtn=document.getElementById('galFilterBtn'),resetBtn=document.getElementById('galResetBtn'),shareBtn=document.getElementById('galShareBtn'),shareRow=document.getElementById('gal-share-row'),shareUrl=document.getElementById('galShareUrl'),copyBtn=document.getElementById('galCopyBtn'),copyToast=document.getElementById('gal-copy-toast'),sharedNotice=document.getElementById('gal-shared-notice'),dispGen=document.getElementById('gal-disp-gen'),dispSub=document.getElementById('gal-disp-sub'),dispTag=document.getElementById('gal-disp-tag'),dispBad=document.getElementById('gal-disp-bad'),cards=document.querySelectorAll('#galleryModal .gallery-card');
    function fmt(s){return s.replace(/(?<=\S) (\s)?(?=\S)/g,'-').trim().toLowerCase();}
    function flickerBtn(b){b.classList.add('gal-flicker');setTimeout(()=>b.classList.remove('gal-flicker'),300);}
    function updateStatusDisplay(g,s,t,b){dispGen.textContent=g||DEFAULT_GEN;dispSub.textContent=s||DEFAULT_SUB;dispTag.textContent=t||'none';dispBad.textContent=b||'none';}
    function highlightActiveCard(sub){cards.forEach(c=>{c.classList.toggle('gal-active',c.dataset.gal===sub);});}
    function getGenValue(){return genSelect.value==='_custom'?genInput.value:genSelect.value;}
    function getSubValue(){return subSelect.value==='_custom'?subInput.value:subSelect.value;}
    genSelect.addEventListener('change',()=>{if(genSelect.value==='_custom'){genInput.style.display='';genInput.focus();}else{genInput.style.display='none';genInput.value='';}});
    subSelect.addEventListener('change',()=>{if(subSelect.value==='_custom'){subInput.style.display='';subInput.focus();}else{subInput.style.display='none';subInput.value='';}});
    function syncGenDropdown(v){const m=[...genSelect.options].find(o=>o.value===v);if(m){genSelect.value=v;genInput.style.display='none';genInput.value='';}else if(v){genSelect.value='_custom';genInput.style.display='';genInput.value=v;}else{genSelect.value=DEFAULT_GEN;genInput.style.display='none';genInput.value='';}}
    function syncSubDropdown(v){const m=[...subSelect.options].find(o=>o.value===v);if(m){subSelect.value=v;subInput.style.display='none';subInput.value='';}else if(v){subSelect.value='_custom';subInput.style.display='';subInput.value=v;}else{subSelect.value=DEFAULT_SUB;subInput.style.display='none';subInput.value='';}}
    syncGenDropdown(localStorage.getItem(STORAGE_KEYS.gen)||'');syncSubDropdown(localStorage.getItem(STORAGE_KEYS.sub)||'');tagInput.value=localStorage.getItem(STORAGE_KEYS.tag)||'';badInput.value=localStorage.getItem(STORAGE_KEYS.bad)||'';
    function parseSharedLink(){const h=window.location.hash;if(!h.includes('#sharedlink='))return false;const gM=h.match(/gen:([^&]*)/),sM=h.match(/galleryname:([^&]*)/),tM=h.match(/tag:([^&]*)/),bM=h.match(/bannedword:([^&]*)/);if(gM&&gM[1])syncGenDropdown(gM[1]);if(sM&&sM[1])syncSubDropdown(sM[1]);if(tM&&tM[1])tagInput.value=decodeURIComponent(tM[1]);if(bM&&bM[1])badInput.value=decodeURIComponent(bM[1]);sharedNotice.style.display='block';return true;}
    const arrivedViaShare=parseSharedLink();
    updateStatusDisplay(getGenValue(),getSubValue(),tagInput.value,badInput.value);highlightActiveCard(fmt(getSubValue())||DEFAULT_SUB);
    function executeFilter(gen,sub,tag,bad){let fG=gen?fmt(gen):DEFAULT_GEN,fS=sub?fmt(sub):DEFAULT_SUB,fT=tag||'',fB=bad||'';let bA=[];if(typeof fB==='string'&&fB.trim()!=='')bA=fB.split(',').map(t=>t.trim()).filter(t=>t!=='');if(fG!==DEFAULT_GEN)localStorage.setItem(STORAGE_KEYS.gen,fG);else localStorage.removeItem(STORAGE_KEYS.gen);if(fS!==DEFAULT_SUB)localStorage.setItem(STORAGE_KEYS.sub,fS);else localStorage.removeItem(STORAGE_KEYS.sub);if(fT)localStorage.setItem(STORAGE_KEYS.tag,fT);else localStorage.removeItem(STORAGE_KEYS.tag);if(bA.length)localStorage.setItem(STORAGE_KEYS.bad,bA.join(', '));else localStorage.removeItem(STORAGE_KEYS.bad);const iframe=document.querySelector('iframe.text-to-image-plugin-gallery');if(!iframe){console.warn('[Gallery Search] iframe not found');return;}const url=new URL(iframe.src);url.searchParams.set('contentFilter','none');url.searchParams.set('channel',fG);url.searchParams.set('subChannel',fS);const hash=url.hash;const dM=hash.match(/^#data=(.+)$/);if(dM){try{const raw=decodeURIComponent(dM[1]);const d=JSON.parse(raw);d.bannedPromptPhrases=[];if(fT)d.bannedPromptPhrases.push(`/^(?!.*(\\b${fT}\\b)).*$/i`);if(bA.length)d.bannedPromptPhrases.push(...bA);if(typeof jail!=='undefined'&&Array.isArray(jail?.bannedPromptPhrases))d.bannedPromptPhrases.push(...jail.bannedPromptPhrases);url.hash='#data='+encodeURIComponent(JSON.stringify(d));}catch(e){console.warn('[Gallery Search] parse error:',e);}}iframe.src='about:blank';setTimeout(()=>{iframe.src=url.toString();},50);updateStatusDisplay(fG,fS,fT,bA.join(', '));highlightActiveCard(fS);}
    filterBtn.addEventListener('click',()=>{flickerBtn(filterBtn);executeFilter(getGenValue(),getSubValue(),tagInput.value,badInput.value);closeGallery();});
    resetBtn.addEventListener('click',()=>{flickerBtn(resetBtn);genSelect.value=DEFAULT_GEN;genInput.value='';genInput.style.display='none';subSelect.value=DEFAULT_SUB;subInput.value='';subInput.style.display='none';tagInput.value='';badInput.value='';shareRow.style.display='none';sharedNotice.style.display='none';if(window.location.hash.includes('#sharedlink='))history.replaceState(null,'',window.location.pathname);executeFilter('','','','');closeGallery();});
    [genInput,subInput,tagInput,badInput].forEach(input=>{input.addEventListener('keydown',e=>{if(e.key==='Enter')filterBtn.click();});});
    shareBtn.addEventListener('click',()=>{flickerBtn(shareBtn);const g=fmt(getGenValue())||DEFAULT_GEN,s=fmt(getSubValue())||DEFAULT_SUB,t=tagInput.value,b=badInput.value;if(!g&&!s&&!t&&!b){shareRow.style.display='none';return;}shareUrl.value=`${SITE_URL}#sharedlink=gen:${encodeURIComponent(g)}&galleryname:${encodeURIComponent(s)}&tag:${encodeURIComponent(t)}&bannedword:${encodeURIComponent(b)}`;shareRow.style.display='block';});
    copyBtn.addEventListener('click',()=>{flickerBtn(copyBtn);if(typeof copyText==='function')copyText(shareUrl.value);else navigator.clipboard.writeText(shareUrl.value).catch(()=>{shareUrl.select();document.execCommand('copy');});copyToast.style.display='block';setTimeout(()=>{copyToast.style.display='none';},1500);});
    cards.forEach(card=>{card.addEventListener('click',()=>{const gal=card.dataset.gal;syncSubDropdown(gal);executeFilter(getGenValue(),gal,tagInput.value,badInput.value);closeGallery();});});
    window._imagGalleryOpen=function(){modal.style.zIndex=20001;modal.hidden=false;setTimeout(()=>{modal.style.opacity=1;},20);};
    function closeGallery(){modal.style.opacity=0;setTimeout(()=>{modal.hidden=true;modal.style.zIndex='';},350);}
    window._imagGalleryClose=closeGallery;
    if(closeBtn)closeBtn.onclick=closeGallery;
    modal.addEventListener('click',e=>{if(e.target===modal)closeGallery();});
    if(arrivedViaShare||getGenValue()!==DEFAULT_GEN||getSubValue()!==DEFAULT_SUB||tagInput.value||badInput.value){const obs=new MutationObserver(()=>{const iframe=document.querySelector('iframe.text-to-image-plugin-gallery');if(iframe){obs.disconnect();setTimeout(()=>{executeFilter(getGenValue(),getSubValue(),tagInput.value,badInput.value);},300);}});obs.observe(document.body,{childList:true,subtree:true});}
})();
</script>

