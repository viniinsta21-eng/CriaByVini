    // Fields: name (required), date (required),
    //         title (optional), img (optional URL)
    // ════════════════════════════════════════
    const WINNERS = [
      { name: 'VoidSinner', date: 'May 2026', title: 'Doggo Parade', img: 'https://files.catbox.moe/tsg2h4.png' },
    ];

    // ════════════════════════════════════════
    // BUTTON TEXT CYCLE — edit as desired
    // ════════════════════════════════════════
    const CYCLE_TEXTS = ['Contest', 'Enter Now', 'HoF'];

    // ── DOM refs ──
    const btn       = document.getElementById('imag-ct-trigger');
    const btnTxt    = document.getElementById('imag-ct-text');
    const modal     = document.getElementById('imag-ct-modal');
    const closeBtn  = document.getElementById('imag-ct-close');
    const tabs      = document.querySelectorAll('#imag-contest-component .imag-ct-tab');
    const panelInfo = document.getElementById('imag-ct-panel-info');
    const panelWin  = document.getElementById('imag-ct-panel-winners');
    const winList   = document.getElementById('imag-ct-winners-list');

    // ── Render winners ──
    if (WINNERS.length === 0) {
      winList.innerHTML =
        `<div class="imag-ct-empty">
          <div class="imag-ct-empty-icon">🏆</div>
          No winners yet.<br>Be the first to claim the crown.
        </div>`;
    } else {
      WINNERS.forEach(w => {
        // If image URL exists, render as <a> linking to image; otherwise plain div
        const card = document.createElement(w.img ? 'a' : 'div');
        card.className = 'imag-ct-winner-card';
        if (w.img) {
          card.href = w.img;
          card.target = '_blank';
          card.rel = 'noopener noreferrer';
          card.title = 'Open full image in new tab';
        }
        const thumb = w.img
          ? `<img class="imag-ct-winner-thumb" src="${w.img}" alt="${w.name}">`
          : `<div class="imag-ct-winner-placeholder">🏆</div>`;
        card.innerHTML = `
          ${thumb}
          <div class="imag-ct-winner-info">
            <div class="imag-ct-winner-name">🥇 ${w.name}</div>
            ${w.title ? `<div class="imag-ct-winner-title">"${w.title}"</div>` : ''}
            <div class="imag-ct-winner-date">${w.date}</div>
          </div>
          ${w.img ? '<div class="imag-ct-winner-ext">↗</div>' : ''}`;
        winList.appendChild(card);
      });
    }

    // ── Tab switching ──
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const isInfo = tab.dataset.tab === 'info';
        panelInfo.classList.toggle('imag-ct-hidden', !isInfo);
        panelWin.classList.toggle('imag-ct-hidden',  isInfo);
      });
    });

    // ── Open / close ──
    btn.addEventListener('click', () => modal.classList.remove('imag-ct-hidden'));
    closeBtn.addEventListener('click', () => modal.classList.add('imag-ct-hidden'));
    modal.addEventListener('click', e => {
      if (e.target === modal) modal.classList.add('imag-ct-hidden');
    });

    // ── Button text cycle ──
    let idx = 0;
    btnTxt.style.transition = 'opacity 0.2s';
    setInterval(() => {
      idx = (idx + 1) % CYCLE_TEXTS.length;
      btnTxt.style.opacity = '0';
      setTimeout(() => {
        btnTxt.textContent = CYCLE_TEXTS[idx];
        btnTxt.style.opacity = '1';
      }, 200);
    }, 3000);

  })();
  </script>

