<style>
.click-effect { position:fixed; pointer-events:none; font-family:'Outfit',sans-serif; font-weight:bold; font-size:18px; text-shadow:0 0 6px,0 0 12px; transition:transform 0.8s ease-out,opacity 0.8s ease-out; z-index:2147483647; }
.spark { position:fixed; width:4px; height:4px; border-radius:50%; pointer-events:none; opacity:1; transition:all 0.6s ease-out; z-index:2147483647; }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const applyNavBtnStyle = (btn) => {
    btn.style.background = "var(--bg-panel)";
    btn.style.color = "var(--text-primary)";
    btn.style.fontFamily = "'Outfit', sans-serif";
    btn.style.fontSize = "11px";
    btn.style.fontWeight = "700";
    btn.style.border = "1px solid var(--border-subtle)";
    btn.style.borderLeft = "4px solid var(--accent)";
    btn.style.borderRadius = "0";
    btn.style.padding = "6px 12px";
    btn.style.textTransform = "uppercase";
    btn.style.letterSpacing = "1px";
    btn.style.cursor = "pointer";
    btn.style.minHeight = "32px";
    btn.style.transition = "background 0.1s, border-color 0.1s";
    btn.onmouseover = () => { btn.style.background = "var(--bg-hover)"; btn.style.borderLeftColor = "var(--accent-light)"; };
    btn.onmouseleave = () => { btn.style.background = "var(--bg-panel)"; btn.style.borderLeftColor = "var(--accent)"; };
  };

  const navBar = document.createElement("div");
  navBar.id = "studio-tools-wrapper";
  navBar.style.cssText = "position:fixed;bottom:35px;left:50%;transform:translateX(-50%);display:flex;justify-content:center;align-items:center;gap:4px;z-index:5000;";

  const navButtons = [
    { text:"Reset", action:"reset", onClick:()=>{document.querySelectorAll('select').forEach(d=>{d.selectedIndex=0;d.dispatchEvent(new Event('change'));});} },
    { text:"Up", action:"up", onClick:()=>window.scrollTo({top:0,behavior:"smooth"}) },
    { text:"✨", action:"scroll", onClick:()=>document.getElementById("generateButtonEl")?.scrollIntoView({behavior:"smooth",block:"center"}) },
    { text:"Down", action:"down", onClick:()=>window.scrollTo({top:document.body.scrollHeight,behavior:"smooth"}) },
    { text:"Generate", action:"generate", onClick:()=>document.getElementById("generateButtonEl")?.click() }
  ];

  navButtons.forEach(cfg => {
    const btn = document.createElement("button");
    btn.textContent = cfg.text;
    applyNavBtnStyle(btn);
    btn.addEventListener("click", () => {
      if (cfg.onClick) cfg.onClick();
      const rect = btn.getBoundingClientRect();
      const x = rect.left + rect.width / 2, y = rect.top;
      if (cfg.action === "generate") {
        const label = document.createElement("div"); label.classList.add("click-effect"); label.textContent = "GENERATING"; label.style.left = x+"px"; label.style.top = y+"px"; document.body.appendChild(label);
        requestAnimationFrame(() => { label.style.transform = "translateY(-80px) scale(1.2)"; label.style.opacity = "0"; }); setTimeout(() => label.remove(), 800);
        for (let i = 0; i < 10; i++) { const s = document.createElement("div"); s.classList.add("spark"); s.style.left = x+"px"; s.style.top = y+"px"; document.body.appendChild(s); const a = Math.random()*Math.PI, d = 40+Math.random()*40; requestAnimationFrame(() => { s.style.transform = `translate(${Math.cos(a)*d}px,${-Math.sin(a)*d}px) scale(0.3)`; s.style.opacity = "0"; }); setTimeout(() => s.remove(), 600); }
      } else if (cfg.action === "reset") {
        const label = document.createElement("div"); label.classList.add("click-effect"); label.textContent = "RESET"; label.style.left = x+"px"; label.style.top = y+"px"; label.style.transition = "transform 0.4s ease-in, opacity 0.4s ease-in"; document.body.appendChild(label);
        requestAnimationFrame(() => { label.style.transform = "scale(1.1)"; }); setTimeout(() => { label.style.transform = "scale(0)"; label.style.opacity = "0"; }, 50); setTimeout(() => label.remove(), 500);
      } else if (cfg.action === "scroll") {
        for (let i = 0; i < 14; i++) { const s = document.createElement("div"); s.classList.add("spark"); s.style.left = x+"px"; s.style.top = y+"px"; document.body.appendChild(s); const a = Math.random()*2*Math.PI, d = 40+Math.random()*40; requestAnimationFrame(() => { s.style.transform = `translate(${Math.cos(a)*d}px,${Math.sin(a)*d}px) scale(0.3)`; s.style.opacity = "0"; }); setTimeout(() => s.remove(), 600); }
      } else {
        const label = document.createElement("div"); label.classList.add("click-effect"); label.textContent = cfg.text.toUpperCase(); label.style.left = x+"px"; label.style.top = y+"px"; document.body.appendChild(label);
        const dir = cfg.action === "down" ? 60 : -60; requestAnimationFrame(() => { label.style.transform = `translateY(${dir}px) scale(1.1)`; label.style.opacity = "0"; }); setTimeout(() => label.remove(), 800);
      }
    });
    navBar.appendChild(btn);
  });
  document.body.appendChild(navBar);

  // ── GALLERY BUTTON ──
  const galleryModal = document.getElementById("galleryModal");
  if (galleryModal) {
    const galleryBtn = document.createElement("button");
    galleryBtn.id = "view-gallery-btn"; galleryBtn.title = "Gallery";
    applyNavBtnStyle(galleryBtn);
    galleryBtn.textContent = "Gallery"; galleryBtn.style.position = "fixed"; galleryBtn.style.right = "3vw"; galleryBtn.style.bottom = "70px"; galleryBtn.style.zIndex = "5000"; galleryBtn.style.minHeight = "32px"; galleryBtn.style.maxHeight = "32px"; galleryBtn.style.display = "flex"; galleryBtn.style.alignItems = "center"; galleryBtn.style.justifyContent = "center";
    galleryBtn.onclick = () => {
      window._imagGalleryOpen();
      const rect = galleryBtn.getBoundingClientRect(), x = rect.left+rect.width/2, y = rect.top+rect.height/2, emojis = ['🖼️','🎨','📷','✨'];
      for (let i = 0; i < 15; i++) { const el = document.createElement("div"); el.textContent = emojis[Math.floor(Math.random()*emojis.length)]; el.style.cssText = `position:fixed;pointer-events:none;font-size:20px;left:${x}px;top:${y}px;transform:translate(-50%,-50%);opacity:1;transition:transform 0.7s ease-out,opacity 0.7s ease-out;z-index:2147483647;`; document.body.appendChild(el); const a = Math.random()*2*Math.PI, d = 60+Math.random()*40; requestAnimationFrame(() => { el.style.transform = `translate(${Math.cos(a)*d-(x-rect.left)}px,${Math.sin(a)*d-(y-rect.top)}px) scale(0.5)`; el.style.opacity = 0; }); setTimeout(() => el.remove(), 700); }
    };
    document.body.appendChild(galleryBtn);
  }
});
</script>

