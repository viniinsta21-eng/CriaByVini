<!-- ══════════════════════════════════════
     GLOBAL STYLES + CSS VARIABLES
     ══════════════════════════════════════ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@400;600;700;900&display=swap');

/* ── THEME VARIABLES ── */
:root {
  --bg-panel:       #1a0515;
  --bg-surface:     #250721;
  --bg-deep:        #0f0208;
  --bg-hover:       #3a1030;
  --bg-active:      #4a1a50;
  --bg-inset:       rgba(255,0,204,0.1);
  --accent:         #ff00cc;
  --accent-light:   #ff33ff;
  --accent-lighter: #ff66ff;
  --accent-bright:  #ff44ff;
  --accent-muted:   #cc0099;
  --accent-dim:     #660066;
  --text-primary:   #f0e0f8;
  --text-secondary: #d0a0e0;
  --text-muted:     #9080a0;
  --text-dim:       #705080;
  --border:         #4a0066;
  --border-accent:  #ff00cc;
  --border-subtle:  #2a1535;
  --alert:          #ff3366;
}

body {
  margin: 0;
  padding: 0;
  font-family: 'Outfit', sans-serif;
  color: var(--text-primary);
  overflow-x: hidden;
  background: linear-gradient(270deg, #0f0208 0%, #3a0066 25%, #0f0208 50%, #4a0088 75%, #0f0208 100%);
  background-size: 600% 600%;
  animation: bgShift 36s ease infinite;
}

@keyframes bgShift {
  0%   { background-position: 0% 50%; }
  25%  { background-position: 50% 60%; }
  50%  { background-position: 100% 50%; }
  75%  { background-position: 50% 40%; }
  100% { background-position: 0% 50%; }
}

/* ══════════════════════════════════════
   INTRO MODAL
   ══════════════════════════════════════ */
.intro-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.95);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 99999;
}
.intro-window {
  width: 90%;
  max-width: 420px;
  background: var(--bg-panel);
  padding: 36px 32px;
  border: 1px solid var(--accent);
  box-shadow: 0 0 40px rgba(255,0,204,0.3), 0 8px 40px rgba(0,0,0,0.9);
  text-align: center;
  position: relative;
  animation: introFadeIn 0.4s ease forwards;
}
@keyframes introFadeIn {
  from { opacity: 0; transform: scale(0.96); }
  to   { opacity: 1; transform: scale(1); }
}
.intro-title {
  margin: 0 0 8px 0;
  font-family: 'Playfair Display', Georgia, serif;
  font-weight: 900;
  font-size: 1.8em;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--accent-light);
}
.intro-subtitle {
  font-size: 11px;
  color: var(--text-dim);
  margin-bottom: 20px;
  letter-spacing: 3px;
  text-transform: uppercase;
}
.intro-text {
  margin-bottom: 24px;
  line-height: 1.6;
  color: var(--accent-light);
  font-size: 0.9em;
}
.intro-btn {
  background: transparent;
  border: 1px solid var(--accent);
  padding: 10px 32px;
  color: var(--accent-light);
  font-family: 'Outfit', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.intro-btn:hover {
  background: var(--accent);
  color: #fff;
}

/* ══════════════��═══════════════════════
   SITE HEADER
   ══════════════════════════════════════ */
.site-header-container {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 30px 0 16px 0;
  position: relative;
  z-index: 10;
}
.site-header-box {
  position: relative;
  max-width: 90%;
  width: 100%;
  background: var(--bg-panel);
  border-left: 4px solid var(--accent);
  border-right: 1px solid var(--accent-dim);
  border-top: 1px solid var(--accent-dim);
  border-bottom: 1px solid var(--accent-dim);
  overflow: hidden;
}
.site-header-box::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(105deg, transparent 30%, var(--accent-dim) 50%, transparent 70%);
  opacity: 0.3;
  animation: scanSweep 5s ease-in-out infinite;
  pointer-events: none;
}
@keyframes scanSweep {
  0%   { left: -60%; }
  60%  { left: 140%; }
  100% { left: 140%; }
}
.site-header-accent-line {
  height: 2px;
  width: 100%;
  overflow: hidden;
}
.site-header-accent-line.top {
  background: linear-gradient(90deg, var(--accent) 0%, var(--accent-light) 40%, transparent 100%);
  animation: lineExpand 2s ease forwards;
}
.site-header-accent-line.bottom {
  background: linear-gradient(90deg, transparent 0%, var(--accent-light) 60%, var(--accent) 100%);
  animation: lineExpand 2s ease forwards;
}
@keyframes lineExpand {
  from { transform: scaleX(0); transform-origin: left; }
  to   { transform: scaleX(1); transform-origin: left; }
}
.site-header-inner {
  padding: 22px 48px 20px 24px;
  text-align: left;
}
.site-header-tag {
  font-family: 'Outfit', sans-serif;
  font-size: 0.68em;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--accent-muted);
  margin-bottom: 10px;
  animation: tagFadeIn 1.2s ease forwards;
  opacity: 0;
}
@keyframes tagFadeIn {
  from { opacity: 0; transform: translateX(-8px); }
  to   { opacity: 1; transform: translateX(0); }
}
.site-title {
  margin: 0;
  font-family: 'Outfit', sans-serif;
  font-weight: 900;
  font-size: clamp(2.2rem, 6vw, 4rem);
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--text-primary);
  line-height: 1;
  animation: titleSlide 1s ease forwards;
  opacity: 0;
}
@keyframes titleSlide {
  from { opacity: 0; transform: translateX(-16px); }
  to   { opacity: 1; transform: translateX(0); }
}
.site-header-divider {
  width: 48px;
  height: 3px;
  background: var(--accent);
  margin: 10px 0;
  animation: dividerGrow 1.4s ease forwards;
  transform-origin: left;
  transform: scaleX(0);
}
@keyframes dividerGrow {
  0%   { transform: scaleX(0); }
  60%  { transform: scaleX(1.1); }
  100% { transform: scaleX(1); }
}
.site-subtitle {
  margin: 0;
  font-family: 'Outfit', sans-serif;
  font-size: 0.75em;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--accent-light);
  animation: tagFadeIn 1.6s ease forwards;
  opacity: 0;
}

/* ══════════════════════════════════════
   CONTENT UTILITY CLASSES
   ══════════════════════════════════════ */
.ix-box {
  border: 1px solid var(--border);
  background: var(--bg-panel);
  padding: 15px;
  margin-bottom: 20px;
}
.ix-box.a   { border-left: 4px solid var(--accent); }
.ix-box.b   { border-left: 4px solid var(--accent-light); }
.ix-box.c   { border-left: 4px solid var(--accent-lighter); }
.ix-box.alt { border-left: 4px solid var(--alert); }

.ix-h {
  margin-top: 0;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 0.95em;
  color: var(--accent-light);
}
.ix-h.ha   { color: var(--accent-light); }
.ix-h.hb   { color: var(--accent-lighter); }
.ix-h.halt { color: var(--alert); }
.ix-h.hac  { color: var(--accent); }

.ix-t  { color: var(--text-secondary); font-size: 0.95em; line-height: 1.4; }
.ix-tm { color: var(--text-muted); font-size: 0.9em; }
.ix-td { color: var(--text-dim); font-size: 0.9em; }
.ix-s  { color: var(--accent-lighter); }

.ix-callout {
  margin-top: 10px;
  padding: 10px;
  background: var(--bg-inset);
  border-left: 3px solid var(--accent);
}
.ix-callout.b { border-left-color: var(--accent-light); }
.ix-callout.c { border-left-color: var(--accent-lighter); }

.ix-banner {
  background: var(--accent);
  padding: 12px;
  text-align: center;
  margin-bottom: 20px;
  border-left: 4px solid var(--accent-bright);
  color: #fff;
  font-family: 'Outfit', sans-serif;
  font-weight: 900;
  font-size: 1.1em;
  letter-spacing: 3px;
  text-transform: uppercase;
}

.ix-divider {
  border-top: 1px solid var(--border);
  padding-top: 10px;
  margin-top: 10px;
}

.ix-list-bordered {
  list-style-type: none;
  padding-left: 0;
}
.ix-list-bordered li {
  margin-bottom: 8px;
  padding-left: 15px;
  border-left: 2px solid var(--accent);
  color: var(--text-muted);
  font-size: 0.9em;
}

/* ══════════════════════════════════════
   CREATIVE MODES PANEL
   ══════════════════════════════════════ */
.creative-modes-container {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin: 20px auto;
  max-width: 100%;
  flex-wrap: wrap;
  padding: 0 10px;
}

.mode-button {
  padding: 12px 20px;
  background: linear-gradient(135deg, #2a0050, #4a0080);
  border: 2px solid #ff00cc;
  color: #ff33ff;
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 0.9em;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  border-radius: 4px;
  transition: all 0.3s ease;
  box-shadow: 0 0 15px rgba(255, 0, 204, 0.2);
}

.mode-button:hover {
  background: linear-gradient(135deg, #4a0080, #6a00a0);
  box-shadow: 0 0 25px rgba(255, 0, 204, 0.5);
  transform: translateY(-2px);
  color: #ff66ff;
}

.mode-button.active {
  background: linear-gradient(135deg, #6a00a0, #8a00c0);
  box-shadow: 0 0 35px rgba(255, 0, 204, 0.8);
  border-color: #ff66ff;
}

</style>

<!-- ══════════════════════════════════════
     MODE SELECTOR BUTTONS
     ══════════════════════════════════════ -->
<div class="creative-modes-container" id="modesContainer">
  <button class="mode-button active" data-mode="t2i">🎨 Text→Image</button>
  <button class="mode-button" data-mode="i2t">📸 Image→Text</button>
  <button class="mode-button" data-mode="i2i">🔄 Image→Image</button>
  <button class="mode-button" data-mode="hyper">⭐ HyperReal</button>
</div>

<!-- ══════════════════════════════════════
     INFO SECTION
     ══════════════════════════════════════ -->
<div id="modeInfoPanel" style="background: rgba(255,0,204,0.05); border: 1px solid #660066; border-radius: 4px; padding: 20px; margin: 20px auto; max-width: 800px; text-align: center;">
  <h2 style="color: #ff33ff; font-family: 'Outfit', sans-serif; letter-spacing: 2px; text-transform: uppercase; margin-top: 0;">✨ MODES ACTIVATED ✨</h2>
  <p id="modeDescription" style="color: #d0a0e0; font-family: 'Outfit', sans-serif; font-size: 0.95em; line-height: 1.6; margin: 15px 0;"></p>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px;">
    <div style="background: rgba(255,0,204,0.1); padding: 15px; border-left: 3px solid #ff00cc; text-align: left;">
      <div style="color: #ff33ff; font-weight: 700; font-size: 0.85em; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px;">Text→Image</div>
      <div style="color: #d0a0e0; font-size: 0.85em; line-height: 1.4;">Generate images from your detailed descriptions. Perfect for creating custom visuals.</div>
    </div>
    <div style="background: rgba(255,0,204,0.1); padding: 15px; border-left: 3px solid #ff00cc; text-align: left;">
      <div style="color: #ff33ff; font-weight: 700; font-size: 0.85em; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px;">Image→Text</div>
      <div style="color: #d0a0e0; font-size: 0.85em; line-height: 1.4;">Upload an image and get detailed analysis and descriptions instantly.</div>
    </div>
    <div style="background: rgba(255,0,204,0.1); padding: 15px; border-left: 3px solid #ff00cc; text-align: left;">
      <div style="color: #ff33ff; font-weight: 700; font-size: 0.85em; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px;">Image→Image</div>
      <div style="color: #d0a0e0; font-size: 0.85em; line-height: 1.4;">Transform and enhance existing images with AI-powered modifications.</div>
    </div>
    <div style="background: rgba(255,0,204,0.1); padding: 15px; border-left: 3px solid #ff00cc; text-align: left;">
      <div style="color: #ff33ff; font-weight: 700; font-size: 0.85em; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px;">HyperReal Mode</div>
      <div style="color: #d0a0e0; font-size: 0.85em; line-height: 1.4;">Generates photorealistic humans ONLY. No animations, drawings, or creatures.</div>
    </div>
  </div>
</div>

<script>
(function() {
  const modes = {
    't2i': {
      title: 'Text→Image',
      desc: 'Create stunning images from your text descriptions. Describe what you want and watch the AI bring it to life.'
    },
    'i2t': {
      title: 'Image→Text',
      desc: 'Upload any image and receive detailed, intelligent analysis and descriptions of its content.'
    },
    'i2i': {
      title: 'Image→Image',
      desc: 'Take an existing image and transform it. Enhance, modify, or completely reimagine it with AI power.'
    },
    'hyper': {
      title: 'HyperReal Mode',
      desc: 'Exclusive mode for photorealistic human generation only. Maximum quality, no animals or drawings.'
    }
  };

  const buttons = document.querySelectorAll('.mode-button');
  const descPanel = document.getElementById('modeDescription');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const mode = btn.dataset.mode;
      const modeData = modes[mode];
      descPanel.textContent = modeData.desc;
      
      console.log('Mode ativado:', mode);
    });
  });

  // Set initial description
  descPanel.textContent = modes['t2i'].desc;
})();
</script>

</body>